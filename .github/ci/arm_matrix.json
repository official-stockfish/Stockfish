{
  "config": [
    {
      "name": "Android NDK aarch64",
      "os": "ubuntu-22.04",
      "simple_name": "android",
      "compiler": "aarch64-linux-android29-clang++",
      "emu": "qemu-aarch64",
      "comp": "ndk",
      "shell": "bash",
      "archive_ext": "tar.gz"
    },
    {
      "name": "Android NDK arm",
      "os": "ubuntu-22.04",
      "simple_name": "android",
      "compiler": "armv7a-linux-androideabi29-clang++",
      "emu": "qemu-arm",
      "comp": "ndk",
      "shell": "bash",
      "archive_ext": "tar.gz"
    }
  ],
  "binaries": [
    "arm64-universal",
    "armv7-neon"
  ],
  "exclude": [
    {
      "binaries": "arm64-universal",
      "config": {
        "compiler": "armv7a-linux-androideabi29-clang++"
      }
    },
    {
      "binaries": "armv7-neon",
      "config": {
        "compiler": "aarch64-linux-android29-clang++"
      }
    }
  ]
}
